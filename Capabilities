        .faq-item {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            margin-bottom: 12px;
            overflow: hidden;
        }
        .faq-item .question {
            padding: 16px 20px;
            font-weight: 600;
            color: #1a3a5c;
            cursor: pointer;
            background: #f7f9fc;
            transition: background 0.2s;
        }
        .faq-item .question:hover {
            background: #edf2f7;
        }
        .faq-item .answer {
            padding: 16px 20px;
            color: #444;
            font-size: 15px;
            border-top: 1px solid #e2e8f0;
            display: none;
        }
        .faq-item .answer.show {
            display: block;
        }
        .faq-item .question::after {
            content: '▾';
            float: right;
            font-size: 18px;
            color: #1a73e8;
        }
        .faq-item .question.active::after {
            content: '▴';
        }

