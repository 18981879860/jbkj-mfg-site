            font-size: 38px;
            font-weight: 700;
            margin-bottom: 12px;
        }
        .page-banner p {
            font-size: 17px;
            max-width: 700px;
            margin: 0 auto 28px;
            color: rgba(255,255,255,0.85);
        }
        .page-banner .btn-white {
            background: #fff;
            color: #1a3a5c;
            padding: 12px 34px;
            border-radius: 30px;
            font-weight: 600;
            display: inline-block;
            transition: background 0.2s;
        }
        .page-banner .btn-white:hover {
            background: #e8f0fe;
            text-decoration: none;
        }

