        .nav-links a:hover {
            color: #fff;
            text-decoration: none;
            border-bottom-color: #6ab0f7;
        }
        .nav-links .btn-nav {
            background: #2a7de1;
            padding: 6px 22px;
            border-radius: 20px;
            border-bottom: none;
            font-weight: 500;
        }
        .nav-links .btn-nav:hover {
            background: #4a9df1;
            border-bottom: none;
        }
        .nav-links .active {
            color: #fff;
            border-bottom-color: #6ab0f7;
        }

        /* ======== 页面横幅 ======== */
